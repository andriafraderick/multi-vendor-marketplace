# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=qwertyuioplkjhgfdsazxcvbnm0987654321qwertyuioplkjhg
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for SQLite (local dev)
# PostgreSQL example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave blank for in-memory cache (local dev)
# Redis example: redis://127.0.0.1:6379/0
REDIS_URL=

# ── Cloudinary (free at cloudinary.com) ──────────────────────────────────────
# Leave blank to store files locally
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe (test keys at stripe.com) ─────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Gmail SMTP — use App Password) ─────────────────────────────────────
# Leave blank to print emails to console
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Platform defaults ─────────────────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=10.0
